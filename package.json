{
  "name": "bs-theme",
  "version": "1.0.0",
  "description": "A custom WordPress theme for BitcoinChaser.com",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:js && npm run build:css && npm run build:tailwind",
    "build:js": "wp-scripts build --config webpack.config.js",
    "build:css": "sass assets/css/style.scss build/style.css --no-source-map --style=compressed",
    "build:tailwind": "npx @tailwindcss/cli -i assets/css/tailwind.css -o build/tailwind.css --minify",
    "watch:css": "sass --watch assets/css/style.scss build/style.css --no-source-map",
    "watch:tailwind": "npx @tailwindcss/cli -i assets/css/tailwind.css -o build/tailwind.css --watch",
    "start": "wp-scripts start",
    "dev": "npm-run-all --parallel watch:css watch:tailwind start"
  },
  "author": "Ross Findlay",
  "license": "ISC",
  "dependencies": {
    "@wordpress/block-editor": "^15.3.0",
    "@wordpress/blocks": "^15.3.0",
    "@wordpress/components": "^30.3.0",
    "@wordpress/element": "^6.30.0",
    "@wordpress/scripts": "^30.19.0",
    "bootstrap-icons": "^1.13.1",
    "feather-icons": "^4.29.2",
    "swiper": "^11.2.10"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.2"
  }
}